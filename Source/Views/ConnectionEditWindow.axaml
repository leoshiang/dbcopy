<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DbCopy.Views.ConnectionEditWindow"
        Title="資料庫連線" Width="600" Height="420"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#2563eb" Padding="16,10">
            <TextBlock x:Name="TitleText" Text="新增資料庫連線" Foreground="White"
                       FontWeight="Bold" FontSize="14" />
        </Border>

        <!-- Footer -->
        <Border DockPanel.Dock="Bottom" Padding="16,10" Background="#f9fafb"
                BorderBrush="#e5e7eb" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto,8,Auto,8,Auto">
                <TextBlock x:Name="TestStatusText" VerticalAlignment="Center"
                           FontSize="12" />
                <Button Grid.Column="1" Content="測試連線" Click="OnTestConnection"
                        Padding="12,6" CornerRadius="12" />
                <Button Grid.Column="3" Content="取消" Click="OnCancel"
                        Padding="12,6" CornerRadius="12" />
                <Button Grid.Column="5" Content="儲存連線" Click="OnSave"
                        Background="#2563eb" Foreground="White" FontWeight="Bold"
                        Padding="12,6" CornerRadius="12" />
            </Grid>
        </Border>

        <!-- Form -->
        <StackPanel Margin="20,16" Spacing="12">
            <StackPanel Spacing="4">
                <TextBlock Text="名稱 (例如: 本地開發 SQL)" FontWeight="SemiBold" FontSize="12" />
                <TextBox x:Name="NameInput" />
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="資料庫類型" FontWeight="SemiBold" FontSize="12" />
                <ComboBox x:Name="TypeCombo" SelectedIndex="0" HorizontalAlignment="Stretch">
                    <ComboBoxItem>Microsoft SQL Server</ComboBoxItem>
                    <ComboBoxItem>PostgreSQL</ComboBoxItem>
                </ComboBox>
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="連線字串" FontWeight="SemiBold" FontSize="12" />
                <TextBox x:Name="ConnStringInput" AcceptsReturn="True"
                         Height="80" TextWrapping="Wrap" />
                <StackPanel Spacing="2" Margin="0,4,0,0">
                    <TextBlock FontSize="11" Foreground="#6b7280">
                        <Run FontWeight="Bold">SQL Server:</Run>
                        <Run Text=" Server=localhost;Database=Db;Trusted_Connection=True;TrustServerCertificate=True;" />
                    </TextBlock>
                    <TextBlock FontSize="11" Foreground="#6b7280">
                        <Run FontWeight="Bold">PostgreSQL:</Run>
                        <Run Text=" Host=localhost;Username=postgres;Password=pwd;Database=Db;" />
                    </TextBlock>
                </StackPanel>
            </StackPanel>

            <CheckBox x:Name="ReadOnlyCheck">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="唯讀連線" FontWeight="Bold" />
                    <TextBlock Text="(唯讀連線無法作為目的資料庫)" Foreground="#6b7280" FontSize="12" />
                </StackPanel>
            </CheckBox>
        </StackPanel>
    </DockPanel>
</Window>

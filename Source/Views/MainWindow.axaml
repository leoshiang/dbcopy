<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DbCopy.ViewModels"
        x:Class="DbCopy.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="資料庫同步工具" Width="1200" Height="800"
        Icon="/app.ico"
        WindowStartupLocation="CenterScreen">

    <DockPanel>
        <!-- Title Bar -->
        <Border DockPanel.Dock="Top" Padding="16,8"
                Background="#2563eb">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="⚙ 資料庫同步工具" Foreground="White" FontWeight="Bold" FontSize="16"
                           VerticalAlignment="Center" />
                <Border Background="#1d4ed8" CornerRadius="8" Padding="8,2">
                    <TextBlock Text="{Binding VersionText}" Foreground="#dbeafe" FontSize="11" />
                </Border>
            </StackPanel>
        </Border>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Padding="12,10"
                Background="#F0F9FF" BorderBrush="#93C5FD" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,12,*,12,*,12,Auto,12,Auto">
                <Button Grid.Column="0" Content="⚙ 管理連線" Click="OnManageConnections"
                        Classes="outline" Padding="12,6" VerticalAlignment="Bottom" />

                <StackPanel Grid.Column="2" Spacing="4">
                    <TextBlock Text="來源" FontWeight="SemiBold" FontSize="11" Foreground="#2563eb" />
                    <ComboBox ItemsSource="{Binding SourceOptions}"
                              SelectedItem="{Binding SelectedSource}"
                              HorizontalAlignment="Stretch"
                              PlaceholderText="-- 選擇來源 --">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:ViewModelBase">
                                <TextBlock Text="{Binding}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="4" Spacing="4">
                    <TextBlock Text="目的地" FontWeight="SemiBold" FontSize="11" Foreground="#2563eb" />
                    <ComboBox ItemsSource="{Binding TargetOptions}"
                              SelectedItem="{Binding SelectedTarget}"
                              HorizontalAlignment="Stretch"
                              PlaceholderText="-- 選擇目的地 --">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:ViewModelBase">
                                <TextBlock Text="{Binding}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="6" Spacing="4" VerticalAlignment="Bottom">
                    <TextBlock Text="批次大小" FontWeight="SemiBold" FontSize="11" Foreground="#2563eb" />
                    <NumericUpDown Value="{Binding BatchSize}" Minimum="1" Increment="500"
                                   FormatString="N0" Width="120" />
                </StackPanel>

                <Button Grid.Column="8" Command="{Binding CompareCommand}"
                        IsEnabled="{Binding !IsComparing}"
                        VerticalAlignment="Bottom" Padding="16,7"
                        Background="#2563eb" Foreground="White" FontWeight="Bold"
                        Height="32">
                    <TextBlock Text="🔍 分析與比較" />
                </Button>
            </Grid>
        </Border>

        <!-- Filter Bar -->
        <Border DockPanel.Dock="Top" Padding="12,6" Background="#fafafa" BorderBrush="#e5e7eb"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,8,Auto,8,Auto,*,Auto,8,Auto">
                <ComboBox Grid.Column="0" SelectedIndex="{Binding FilterTypeIndex}" Width="130"
                          FontSize="12">
                    <ComboBoxItem>所有類型</ComboBoxItem>
                    <ComboBoxItem>Type</ComboBoxItem>
                    <ComboBoxItem>Table Type</ComboBoxItem>
                    <ComboBoxItem>Sequence</ComboBoxItem>
                    <ComboBoxItem>Table</ComboBoxItem>
                    <ComboBoxItem>View</ComboBoxItem>
                    <ComboBoxItem>Procedure</ComboBoxItem>
                    <ComboBoxItem>Function</ComboBoxItem>
                </ComboBox>

                <ComboBox Grid.Column="2" SelectedIndex="{Binding FilterDestIndex}" Width="140"
                          FontSize="12">
                    <ComboBoxItem>所有目的狀態</ComboBoxItem>
                    <ComboBoxItem>不存在 (Missing)</ComboBoxItem>
                    <ComboBoxItem>已存在 (Exists)</ComboBoxItem>
                </ComboBox>

                <ComboBox Grid.Column="4" SelectedIndex="{Binding FilterSyncIndex}" Width="140"
                          FontSize="12">
                    <ComboBoxItem>所有同步狀態</ComboBoxItem>
                    <ComboBoxItem>準備就緒</ComboBoxItem>
                    <ComboBoxItem>不同步</ComboBoxItem>
                    <ComboBoxItem>成功</ComboBoxItem>
                    <ComboBoxItem>錯誤</ComboBoxItem>
                </ComboBox>

                <!-- Stats -->
                <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="12"
                            VerticalAlignment="Center" Margin="16,0,0,0">
                    <TextBlock FontSize="12" Foreground="#6b7280">
                        <Run Text="共 " /><Run Text="{Binding TotalCount}" FontWeight="Bold"
                                               Foreground="#1e293b" /><Run Text=" 個物件" />
                    </TextBlock>
                    <TextBlock Text="|" Foreground="#d1d5db" />
                    <TextBlock FontSize="12" Foreground="#6b7280">
                        <Run Text="篩選 " /><Run Text="{Binding FilteredCount}" FontWeight="Bold"
                                                  Foreground="#1e293b" /><Run Text=" 個" />
                    </TextBlock>
                    <TextBlock Text="|" Foreground="#d1d5db" />
                    <TextBlock FontSize="12" Foreground="#6b7280">
                        <Run Text="已選 " /><Run Text="{Binding SelectedCount}" FontWeight="Bold"
                                                  Foreground="#2563eb" /><Run Text=" 個" />
                    </TextBlock>
                </StackPanel>

                <Button Grid.Column="6" Command="{Binding SyncCommand}"
                        IsVisible="{Binding !IsSyncing}"
                        Background="#ea580c" Foreground="White" FontWeight="Bold" Padding="16,6">
                    <TextBlock Text="↻ 同步選取項目" />
                </Button>
                <Button Grid.Column="6" Command="{Binding StopSyncCommand}"
                        IsVisible="{Binding IsSyncing}"
                        Background="#dc2626" Foreground="White" FontWeight="Bold" Padding="16,6">
                    <TextBlock Text="⏹ 中斷" />
                </Button>
            </Grid>
        </Border>

        <!-- Progress Bar -->
        <Border DockPanel.Dock="Top" IsVisible="{Binding ShowProgress}" Padding="12,4">
            <StackPanel Spacing="2">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="同步進度" FontSize="11" Foreground="#6b7280" />
                    <TextBlock Grid.Column="1" Text="{Binding SyncProgressText}"
                               FontWeight="Bold" Foreground="#2563eb" FontSize="11" />
                </Grid>
                <ProgressBar Value="{Binding SyncProgress}" Minimum="0" Maximum="100"
                             Height="6" Foreground="#2563eb" />
            </StackPanel>
        </Border>

        <!-- Result Banner -->
        <Border DockPanel.Dock="Top" IsVisible="{Binding ShowResultBanner}" Padding="12,8"
                Margin="12,4" CornerRadius="6"
                Background="{Binding IsResultSuccess,
                    Converter={StaticResource BoolToBannerBg}}">
            <TextBlock Text="{Binding ResultBannerText}" FontWeight="SemiBold" FontSize="12"
                       Foreground="{Binding IsResultSuccess,
                           Converter={StaticResource BoolToBannerFg}}" />
        </Border>

        <!-- Table Header -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="36,36,*,90,110,180"
              Background="#2563eb" Height="36" Margin="0,4,0,0">
            <Panel Grid.Column="0" />
            <CheckBox Grid.Column="1" x:Name="SelectAllCheck"
                      Click="OnSelectAllClick"
                      VerticalAlignment="Center" HorizontalAlignment="Center" />
            <TextBlock Grid.Column="2" Text="物件名稱" Foreground="White" FontWeight="SemiBold"
                       FontSize="12" VerticalAlignment="Center" Margin="8,0" />
            <TextBlock Grid.Column="3" Text="物件類型" Foreground="White" FontWeight="SemiBold"
                       FontSize="12" VerticalAlignment="Center" />
            <TextBlock Grid.Column="4" Text="目的狀態" Foreground="White" FontWeight="SemiBold"
                       FontSize="12" VerticalAlignment="Center" />
            <TextBlock Grid.Column="5" Text="同步狀態" Foreground="White" FontWeight="SemiBold"
                       FontSize="12" VerticalAlignment="Center" />
        </Grid>

        <!-- Placeholder -->
        <TextBlock DockPanel.Dock="Top" IsVisible="{Binding ShowPlaceholder}"
                   Text="{Binding PlaceholderText}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="#6b7280" FontSize="14" Margin="0,60" />

        <!-- Main List -->
        <ListBox ItemsSource="{Binding VisibleRows}"
                 IsVisible="{Binding !ShowPlaceholder}"
                 SelectionMode="Single"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="MinHeight" Value="0" />
                </Style>
            </ListBox.Styles>
            <ListBox.DataTemplates>
                <!-- Schema Row -->
                <DataTemplate DataType="{x:Type vm:SchemaRow}">
                    <Border Background="#DBEAFE" BorderBrush="#93C5FD" BorderThickness="0,0,0,1"
                            Padding="0,2">
                        <Grid ColumnDefinitions="36,36,*,90,110,180" MinHeight="32">
                            <Button Grid.Column="0" Content="{Binding ExpandIcon}"
                                    Command="{Binding ToggleExpandCommand}"
                                    Background="Transparent" BorderThickness="0"
                                    HorizontalContentAlignment="Center"
                                    FontSize="14" FontWeight="Bold" Foreground="#374151"
                                    Width="28" Height="28" Padding="0" />
                            <CheckBox Grid.Column="1" IsChecked="{Binding IsChecked}"
                                      VerticalAlignment="Center" HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="8,0"
                                       FontWeight="Bold" Foreground="#1f2937">
                                <Run Text="🗄 " /><Run Text="{Binding SchemaName}" />
                            </TextBlock>
                        </Grid>
                    </Border>
                </DataTemplate>

                <!-- Type Group Row -->
                <DataTemplate DataType="{x:Type vm:TypeGroupRow}">
                    <Border Background="#F0F9FF" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1"
                            Padding="0,1">
                        <Grid ColumnDefinitions="36,36,*,90,110,180" MinHeight="28">
                            <Button Grid.Column="0" Content="{Binding ExpandIcon}"
                                    Command="{Binding ToggleExpandCommand}"
                                    Background="Transparent" BorderThickness="0"
                                    HorizontalContentAlignment="Center"
                                    FontSize="12" Foreground="#4b5563"
                                    Width="28" Height="28" Padding="0" Margin="12,0,0,0" />
                            <CheckBox Grid.Column="1" IsChecked="{Binding IsChecked}"
                                      VerticalAlignment="Center" HorizontalAlignment="Center" />
                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                        VerticalAlignment="Center" Margin="20,0,0,0" Spacing="6">
                                <TextBlock Text="{Binding TypeLabel}" FontWeight="SemiBold"
                                           Foreground="#374151" />
                                <Border Background="#E5E7EB" CornerRadius="10" Padding="6,1">
                                    <TextBlock Text="{Binding Count}" FontSize="11"
                                               Foreground="#4b5563" />
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>

                <!-- Object Row -->
                <DataTemplate DataType="{x:Type vm:ObjectRow}">
                    <Border BorderBrush="#f3f4f6" BorderThickness="0,0,0,1"
                            Background="{Binding IsSuccess, Converter={StaticResource BoolToRowBg}}">
                        <Grid ColumnDefinitions="36,36,*,90,110,180" MinHeight="30">
                            <Panel Grid.Column="0" />
                            <CheckBox Grid.Column="1" IsChecked="{Binding IsChecked}"
                                      IsEnabled="{Binding CanCheck}"
                                      VerticalAlignment="Center" HorizontalAlignment="Center" />
                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                        VerticalAlignment="Center" Margin="32,0,0,0" Spacing="4">
                                <TextBlock Text="·" Foreground="#9ca3af" FontWeight="Bold" />
                                <TextBlock Text="{Binding ObjectName}" FontWeight="SemiBold"
                                           Foreground="#1e293b" />
                                <Border IsVisible="{Binding IsTable}" Background="#f3f4f6"
                                        CornerRadius="4" Padding="4,1" Margin="4,0,0,0">
                                    <TextBlock Text="{Binding SourceRowCount}"
                                               FontSize="11" Foreground="#6b7280" />
                                </Border>
                                <TextBlock IsVisible="{Binding IsSuccess}" FontSize="11"
                                           Foreground="#6b7280" Margin="4,0,0,0">
                                    <Run Text="(目的: " /><Run Text="{Binding DisplayTargetRowCount}" /><Run Text=")" />
                                </TextBlock>
                            </StackPanel>

                            <!-- Type Badge -->
                            <Border Grid.Column="3" CornerRadius="10" Padding="8,2"
                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                    Background="{Binding TypeBadgeColor}">
                                <TextBlock Text="{Binding TypeBadgeText}" FontSize="10"
                                           Foreground="White" FontWeight="SemiBold" />
                            </Border>

                            <!-- Dest Status -->
                            <TextBlock Grid.Column="4" Text="{Binding DestStatusText}"
                                       Foreground="{Binding DestStatusColor}"
                                       VerticalAlignment="Center" FontSize="12"
                                       FontWeight="SemiBold" />

                            <!-- Sync Status -->
                            <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="6"
                                        VerticalAlignment="Center">
                                <!-- Spinner when syncing -->
                                <Border IsVisible="{Binding IsSyncing}" Width="12" Height="12"
                                        CornerRadius="6" BorderThickness="2"
                                        BorderBrush="#2563eb" />
                                <TextBlock Text="{Binding SyncStatusText}" FontSize="12"
                                           FontWeight="Medium"
                                           Foreground="{Binding SyncStatusColor}" />
                                <!-- Error detail button -->
                                <Button IsVisible="{Binding IsError}"
                                        Content="ⓘ" FontSize="11"
                                        Background="Transparent" BorderThickness="0"
                                        Foreground="#dc2626" Padding="2"
                                        Click="OnShowError"
                                        Tag="{Binding ErrorMessage}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>

                <!-- Index Row -->
                <DataTemplate DataType="{x:Type vm:IndexRow}">
                    <Border Background="#FEFCE8" BorderBrush="#FEF3C7" BorderThickness="0,0,0,1"
                            Padding="0,1">
                        <Grid ColumnDefinitions="36,36,*,90,110,180" MinHeight="24">
                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                        VerticalAlignment="Center" Margin="48,0,0,0" Spacing="4">
                                <TextBlock Text="↳" Opacity="0.4" />
                                <TextBlock Text="🔑" FontSize="10" />
                                <TextBlock Text="{Binding DisplayText}" FontSize="11"
                                           FontStyle="Italic" Foreground="#6b7280" />
                            </StackPanel>
                            <TextBlock Grid.Column="3" Text="Index" FontSize="10"
                                       Foreground="#9ca3af" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="4" Text="{Binding SyncedText}"
                                       FontSize="11" VerticalAlignment="Center"
                                       Foreground="{Binding SyncedColor}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.DataTemplates>
        </ListBox>
    </DockPanel>

    <Window.Resources>
        <!-- Boolean to banner background color -->
        <SolidColorBrush x:Key="SuccessBannerBg" Color="#d1fae5" />
        <SolidColorBrush x:Key="DangerBannerBg" Color="#fecaca" />
        <SolidColorBrush x:Key="SuccessBannerFg" Color="#065f46" />
        <SolidColorBrush x:Key="DangerBannerFg" Color="#991b1b" />
        <SolidColorBrush x:Key="SuccessRowBg" Color="#d1fae5" />
        <SolidColorBrush x:Key="NormalRowBg" Color="White" />
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Button.outline">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#2563eb" />
            <Setter Property="Foreground" Value="#2563eb" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="CornerRadius" Value="16" />
        </Style>
    </Window.Styles>
</Window>
